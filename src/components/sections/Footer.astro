---
import Logo from "@/components/ui/Logo.astro";
import ToTop from "@/components/widgets/ToTop.astro";
import { siteConfig, socialLinks } from "@/config/site.js";

const currentYear = new Date().getFullYear();
const copyright = `2019-${currentYear}`;
---

<section class="text-gray-700 border-t mt-20 md:mt-48 border-dashed border-primary/15 dark:border-primary-dark/15 border-[.75px]">
  <div class="container mx-auto px-7 max-w-7xl py-12 md:py-16">
    <!-- Top: Logo + Description -->
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8 mb-12">
      <div class="max-w-sm">
        <Logo />
        <p class="mt-4 text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">
          分享编程、嵌入式、Android、PCB等技术领域的学习经验与总结。
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 md:gap-12">
        <!-- Pages -->
        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4">页面</h4>
          <ul class="space-y-3">
            <li><a href="/" class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors">首页</a></li>
            <li><a href="/blog" class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors">博客</a></li>
            <li><a href="/tags" class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors">标签</a></li>
            <li><a href="/about" class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors">关于</a></li>
          </ul>
        </div>

        <!-- Explore -->
        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4">浏览</h4>
          <ul class="space-y-3">
            <li><a href="/archives" class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors">归档</a></li>
            <li><a href="/search" class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors">搜索</a></li>
            <li><a href="/rss.xml" class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors">RSS</a></li>
          </ul>
        </div>

        <!-- Social -->
        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4">社交</h4>
          <ul class="space-y-3">
            <li><a href={siteConfig.social.github} target="_blank" class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors">GitHub</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-dashed border-primary/10 dark:border-primary-dark/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-neutral-400 dark:text-neutral-500">
        © {copyright} <a href={siteConfig.url} target="_blank" class="hover:text-primary dark:hover:text-primary-light transition-colors">{siteConfig.author}</a>.
      </p>

      <div class="flex items-center gap-4">
        <span class="inline-flex items-center gap-2 text-xs text-neutral-400 dark:text-neutral-500">
          <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full border border-dashed border-primary/30 text-primary/80">
            <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
            Astro & Tailwind
          </span>
        </span>
        <span class="inline-flex justify-center space-x-4">
          {socialLinks.map((social) => (
            <a
              href={social.url}
              target="_blank"
              class="footer-social-icon-link text-neutral-400 dark:text-neutral-500 hover:text-primary dark:hover:text-primary-light transition-colors duration-200"
              title={social.name}
            >
              <span class="sr-only">{social.name}</span>
              <div class="footer-social-icon">
                <Fragment set:html={social.icon} />
              </div>
            </a>
          ))}
        </span>
      </div>
    </div>
  </div>
</section>

<!-- Back to top -->
<ToTop />

<style is:global>
  .footer-social-icon { width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .footer-social-icon svg { width: 18px; height: 18px; fill: currentColor; }
  .footer-social-icon-link:hover .ic-github { color: #333; }
  .footer-social-icon-link:hover .ic-rss { color: #F26522; }
</style>
