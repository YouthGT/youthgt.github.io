---
import { Moon, SunMedium, ChevronDown, ChevronRight, Menu, X } from "@lucide/astro";

import menus from "@/collections/menu.json";
import Logo from "@/components/ui/Logo.astro";
---

<!-- Spacer for fixed header -->
<div class="relative w-full h-16 sm:h-20 opacity-0 pointer-events-none"></div>
<header id="header" class="fixed top-2 sm:top-4 z-50 w-full px-3 sm:px-4 lg:px-6">
  <div id="site-container"
    class="flex items-center justify-between h-14 sm:h-15 site-container mx-auto px-4 sm:px-6 py-2.5 border-transparent border-[0.5px] transition-all duration-300"
  >
    <!-- Logo -->
    <div class="flex-shrink-0 z-50">
      <Logo />
    </div>

    <!-- Mobile Menu Background Overlay -->
    <div
      id="mobileMenuBackground"
      class="fixed inset-0 z-20 hidden w-screen h-screen duration-300 ease-out bg-white/90 backdrop-blur-sm dark:bg-neutral-950/90"
    >
    </div>

    <!-- Navigation -->
    <nav
      class="relative z-30 flex flex-row-reverse justify-start w-full text-sm sm:justify-end text-neutral-500 dark:text-neutral-400 sm:flex-row sm:items-center"
    >
      <!-- Mobile Menu Toggle Buttons -->
      <div class="flex items-center gap-2 sm:hidden">
        <!-- Dark Mode Toggle (Mobile) -->
        <div
          id="darkToggleMobile"
          class="flex items-center justify-center w-10 h-10 cursor-pointer rounded-full bg-gradient-to-b from-white to-[#edeefa] border-[0.5px] border-[#f3f3ff] dark:from-neutral-800 dark:to-neutral-600 dark:border-neutral-600 transition-transform duration-200 active:scale-95"
        >
          <div
            class="flex justify-center items-center w-6 h-6 relative overflow-hidden rounded-full bg-[#7fa1ff] bg-gradient-to-b from-[#85a6ff] to-[#2d6dc3] border-[0.5px] border-[#7fa1ff]"
            style="box-shadow: 0px 2px 3px 0 rgba(55,52,209,0.21);"
          >
            <SunMedium class="absolute hidden text-white w-4 h-4 transition duration-200 transform ease mobile-sun" />
            <Moon class="absolute hidden text-white w-4 h-4 transition duration-200 transform ease mobile-moon" />
          </div>
        </div>

        <!-- Hamburger Menu Button -->
        <button
          type="button"
          id="openMenu"
          aria-label="Open menu"
          class="flex items-center justify-center w-10 h-10 cursor-pointer rounded-full bg-gradient-to-b from-white to-[#edeefa] border-[0.5px] border-[#f3f3ff] dark:from-neutral-800 dark:to-neutral-600 dark:border-neutral-600 transition-all duration-200 hover:shadow-md active:scale-90"
        >
          <Menu class="w-5 h-5 text-neutral-700 dark:text-neutral-200" stroke-width={2} />
        </button>

        <!-- Close Menu Button -->
        <button
          type="button"
          id="closeMenu"
          aria-label="Close menu"
          class="hidden items-center justify-center w-10 h-10 cursor-pointer rounded-full bg-gradient-to-b from-white to-[#edeefa] border-[0.5px] border-[#f3f3ff] dark:from-neutral-800 dark:to-neutral-600 dark:border-neutral-600 transition-all duration-200 hover:shadow-md active:scale-90"
        >
          <X class="w-5 h-5 text-neutral-700 dark:text-neutral-200" stroke-width={2} />
        </button>
      </div>

      <!-- Menu Items -->
      <div
        id="menu"
        class="fixed top-[68px] sm:top-0 left-3 right-3 sm:left-0 sm:right-0 ease-out duration-300 z-40 flex-col items-center justify-start hidden w-auto h-auto text-sm pt-4 pb-4 sm:py-0 sm:relative sm:flex-row sm:flex"
      >
        <!-- Mobile Menu Background -->
        <div class="absolute inset-0 top-0 right-0 block w-full h-full sm:hidden">
          <div
            class="relative w-full h-full bg-white/95 dark:bg-bg-primary-dark/95 border border-dashed border-neutral-300 dark:border-neutral-700 backdrop-blur-md rounded-2xl shadow-lg"
          >
          </div>
        </div>

        <!-- Menu Links -->
        <div class="relative z-10 flex flex-col sm:flex-row items-stretch sm:items-center w-full sm:w-auto px-2 sm:px-0 gap-0.5 sm:gap-0">
          <!-- Mobile menu label -->
          <div class="block sm:hidden px-3 pt-1 pb-2">
            <span class="text-[10px] font-medium uppercase tracking-[0.14em] text-neutral-400 dark:text-neutral-500">Navigation</span>
          </div>
          {
            menus.map((menu) => {
              if (menu.children && menu.children.length > 0) {
                return (
                  <div class="dropdown-wrapper relative w-full sm:w-auto" data-open="false">
                    <button
                      type="button"
                      class="dropdown-toggle group relative flex items-center justify-between sm:justify-center w-full sm:w-auto px-3 py-3 sm:py-2 sm:px-3 md:px-4 font-medium tracking-wide duration-200 ease-out rounded-lg sm:rounded-none text-neutral-700 dark:text-neutral-200 hover:text-primary hover:bg-primary/5 sm:hover:bg-transparent dark:hover:text-white dark:hover:bg-primary/10 sm:dark:hover:bg-transparent active:scale-[0.98] sm:active:scale-100 transition-all gap-1 text-left sm:text-center"
                      aria-expanded="false"
                      aria-haspopup="true"
                    >
                      <span class="flex-1 sm:flex-initial">{menu.name}</span>
                      <ChevronDown class="dropdown-chevron w-4 h-4 transition-transform duration-200 text-neutral-400 group-hover:text-primary dark:text-neutral-500" />
                    </button>
                    <div class="dropdown-panel sm:absolute sm:top-full sm:left-1/2 sm:mt-2 sm:min-w-[180px] sm:rounded-xl sm:border sm:border-dashed sm:border-primary/20 dark:sm:border-neutral-700 sm:bg-white/95 dark:sm:bg-bg-secondary-dark sm:p-2 hidden sm:invisible sm:opacity-0 sm:flex sm:flex-col sm:transition-all sm:duration-200">
                      {menu.children.map((child) => (
                        <a
                          href={child.url}
                          class="dropdown-link group/link flex items-center justify-between sm:justify-start w-full px-3 sm:px-4 py-2.5 sm:py-2 rounded-md text-sm font-medium text-neutral-600 dark:text-neutral-300 hover:text-primary dark:hover:text-primary-light hover:bg-primary/5 dark:hover:bg-primary/10 transition-colors duration-150 text-left"
                        >
                          <span>{child.name}</span>
                          <ChevronRight class="w-3.5 h-3.5 sm:hidden text-neutral-300 dark:text-neutral-600 group-hover/link:text-primary transition-colors" />
                        </a>
                      ))}
                    </div>
                  </div>
                );
              }
              return (
                <a
                  href={menu.url}
                  class="group relative flex items-center justify-between sm:justify-center w-full sm:w-auto px-3 py-3 sm:py-2 sm:px-3 md:px-4 font-medium tracking-wide duration-200 ease-out rounded-lg sm:rounded-none text-neutral-700 dark:text-neutral-200 hover:text-primary hover:bg-primary/5 sm:hover:bg-transparent dark:hover:text-white dark:hover:bg-primary/10 sm:dark:hover:bg-transparent active:scale-[0.98] sm:active:scale-100 transition-all text-left sm:text-center"
                >
                  <span>{menu.name}</span>
                  <ChevronRight class="w-4 h-4 sm:hidden text-neutral-300 dark:text-neutral-600 group-hover:text-primary group-hover:translate-x-0.5 transition-all" />
                </a>
              );
            })
          }
        </div>
      </div>

      <!-- Desktop Actions -->
      <div class="relative hidden sm:flex items-center gap-2 ml-4 lg:ml-6">
        <!-- Dark Mode Toggle (Desktop) -->
        <div
          id="darkToggle"
          class="relative flex items-center h-9 px-2 gap-1.5 font-medium cursor-pointer rounded-full bg-gradient-to-b from-white to-[#edf1fa] border-[0.5px] border-[#f3f5ff] dark:from-neutral-800 dark:to-neutral-600 dark:border-neutral-600 transition-all duration-200 hover:shadow-md hover:scale-105 active:scale-95"
        >
          <div
            class="flex justify-center items-center flex-shrink-0 w-6 h-6 relative overflow-hidden rounded-full bg-gradient-to-b from-[#85a6ff] to-[#2d6dc3] border-[0.5px] border-[#7fa1ff]"
            style="box-shadow: 0px 2px 3px 0 rgba(55,52,209,0.21);"
          >
            <SunMedium id="sun"
               class="absolute hidden text-white w-4 h-4 transition duration-200 transform ease" />
            <Moon class="absolute hidden text-white w-4 h-4 transition duration-200 transform ease"
              id="moon" />
          </div>
          <span class="hidden sm:inline-block whitespace-nowrap">
            <span id="dayText" class="flex-shrink-0 text-sm text-left text-[#6f6c8f] dark:text-neutral-400">Light</span>
            <span id="nightText" class="hidden flex-shrink-0 text-sm text-left text-[#6f6c8f] dark:text-neutral-400">Dark</span>
          </span>
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  #header { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }

  @media (max-width: 639px) {
    #menu { max-width: calc(100vw - 24px); }
    #menu {
      transform: translateY(-10px);
      opacity: 0;
      pointer-events: none;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    #menu:not(.hidden) {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }
    #menu:not(.hidden) > div > a,
    #menu:not(.hidden) > div > .dropdown-wrapper {
      animation: menuItemIn 0.4s cubic-bezier(0.4, 0, 0.2, 1) both;
    }
    #menu:not(.hidden) > div > a:nth-child(2),
    #menu:not(.hidden) > div > .dropdown-wrapper:nth-child(2) { animation-delay: 0.05s; }
    #menu:not(.hidden) > div > a:nth-child(3),
    #menu:not(.hidden) > div > .dropdown-wrapper:nth-child(3) { animation-delay: 0.1s; }
    #menu:not(.hidden) > div > a:nth-child(4),
    #menu:not(.hidden) > div > .dropdown-wrapper:nth-child(4) { animation-delay: 0.15s; }
    #menu:not(.hidden) > div > a:nth-child(5),
    #menu:not(.hidden) > div > .dropdown-wrapper:nth-child(5) { animation-delay: 0.2s; }
  }

  @keyframes menuItemIn {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    #menu:not(.hidden) > div > a,
    #menu:not(.hidden) > div > .dropdown-wrapper { animation: none; }
  }

  @media (min-width: 640px) {
    nav a::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%) scaleX(0);
      width: 70%;
      height: 2px;
      background: var(--color-primary);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      border-radius: 2px;
    }
    nav a:hover::after { transform: translateX(-50%) scaleX(1); }
    .dropdown-panel a::after { display: none; }
  }

  @media (min-width: 640px) {
    .dropdown-panel { translate: -50% -4px; }
    .dropdown-wrapper:hover .dropdown-panel,
    .dropdown-wrapper:focus-within .dropdown-panel,
    .dropdown-wrapper[data-open="true"] .dropdown-panel {
      opacity: 1 !important;
      visibility: visible !important;
      translate: -50% 0;
    }
    .dropdown-wrapper:hover .dropdown-chevron,
    .dropdown-wrapper:focus-within .dropdown-chevron,
    .dropdown-wrapper[data-open="true"] .dropdown-chevron { transform: rotate(180deg); }
    .dropdown-wrapper::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      height: 10px;
    }
  }

  @media (max-width: 639px) {
    .dropdown-panel { display: none; width: calc(100% - 0.75rem); margin-left: 0.75rem; padding-left: 0.75rem; margin-top: 0.25rem; margin-bottom: 0.25rem; border-left: 1px dashed rgba(45, 109, 195, 0.3); }
    .dark .dropdown-panel { border-left-color: rgba(140, 180, 240, 0.25); }
    .dropdown-wrapper[data-open="true"] .dropdown-panel { display: flex; flex-direction: column; animation: dropdownIn 0.25s cubic-bezier(0.4, 0, 0.2, 1) both; }
    .dropdown-wrapper[data-open="true"] .dropdown-chevron { transform: rotate(180deg); }
  }

  @keyframes dropdownIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  #darkToggle, #darkToggleMobile {
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  @supports (backdrop-filter: blur(12px)) {
    #mobileMenuBackground { backdrop-filter: blur(12px); }
    @media (max-width: 639px) { #menu > div > div { backdrop-filter: blur(16px); } }
  }

  .flex-shrink-0 { min-width: fit-content; }

  @media (min-width: 640px) and (max-width: 767px) {
    nav a { padding-left: 0.5rem; padding-right: 0.5rem; font-size: 0.8125rem; }
  }

  @media (max-width: 639px) { body { overflow-x: hidden; } }
  @media (max-width: 639px) { button, a, [role="button"] { -webkit-tap-highlight-color: transparent; } }

  @media (max-width: 639px) {
    #mobileMenuBackground { opacity: 0; transition: opacity 0.3s ease-out; }
    #mobileMenuBackground:not(.hidden) { opacity: 1; }
  }
</style>

<script>
  declare global {
    interface Window { closeMobileMenu: () => void; }
  }

  const darkToggle = document.getElementById('darkToggle');
  const darkToggleMobile = document.getElementById('darkToggleMobile');

  function syncDarkModeIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    const sunIcons = document.querySelectorAll('#sun, .mobile-sun');
    const moonIcons = document.querySelectorAll('#moon, .mobile-moon');
    if (isDark) {
      moonIcons.forEach(icon => icon.classList.remove('hidden'));
      sunIcons.forEach(icon => icon.classList.add('hidden'));
      document.getElementById('dayText')?.classList.add('hidden');
      document.getElementById('nightText')?.classList.remove('hidden');
    } else {
      sunIcons.forEach(icon => icon.classList.remove('hidden'));
      moonIcons.forEach(icon => icon.classList.add('hidden'));
      document.getElementById('dayText')?.classList.remove('hidden');
      document.getElementById('nightText')?.classList.add('hidden');
    }
  }

  document.addEventListener('DOMContentLoaded', syncDarkModeIcons);

  const observer = new MutationObserver(syncDarkModeIcons);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

  darkToggleMobile?.addEventListener('click', () => { darkToggle?.click(); });

  const openMenu = document.getElementById('openMenu');
  const closeMenu = document.getElementById('closeMenu');
  const menu = document.getElementById('menu');
  const mobileMenuBackground = document.getElementById('mobileMenuBackground');

  function openMobileMenu() {
    menu?.classList.remove('hidden');
    mobileMenuBackground?.classList.remove('hidden');
    openMenu?.classList.add('hidden');
    closeMenu?.classList.remove('hidden');
    closeMenu?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeMobileMenu() {
    menu?.classList.add('hidden');
    mobileMenuBackground?.classList.add('hidden');
    closeMenu?.classList.add('hidden');
    closeMenu?.classList.remove('flex');
    openMenu?.classList.remove('hidden');
    document.body.style.overflow = '';
  }

  window.closeMobileMenu = closeMobileMenu;

  openMenu?.addEventListener('click', openMobileMenu);
  closeMenu?.addEventListener('click', closeMobileMenu);
  mobileMenuBackground?.addEventListener('click', closeMobileMenu);

  const menuLinks = menu?.querySelectorAll('a');
  menuLinks?.forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth < 640) { closeMobileMenu(); }
    });
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 640) {
      document.body.style.overflow = '';
      if (menu?.classList.contains('hidden')) { menu.classList.remove('hidden'); }
    }
  });

  // Dropdown menus
  const dropdownToggles = document.querySelectorAll('.dropdown-toggle');
  function closeAllDropdowns(except?: Element) {
    document.querySelectorAll('.dropdown-wrapper').forEach(w => {
      if (w !== except) { w.setAttribute('data-open', 'false'); w.querySelector('.dropdown-toggle')?.setAttribute('aria-expanded', 'false'); }
    });
  }
  dropdownToggles.forEach(toggle => {
    toggle.addEventListener('click', e => {
      if (window.innerWidth >= 640) return;
      e.preventDefault(); e.stopPropagation();
      const wrapper = toggle.closest('.dropdown-wrapper');
      if (!wrapper) return;
      const isOpen = wrapper.getAttribute('data-open') === 'true';
      closeAllDropdowns(wrapper);
      wrapper.setAttribute('data-open', isOpen ? 'false' : 'true');
      toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    });
  });

  document.querySelectorAll('.dropdown-panel a').forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth < 640) { setTimeout(() => { closeAllDropdowns(); closeMobileMenu(); }, 0); }
    });
  });

  window.addEventListener('resize', () => { if (window.innerWidth >= 640) closeAllDropdowns(); });
</script>
