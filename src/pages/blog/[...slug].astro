---
import { getCollection, render } from "astro:content";
import PostLayout from "@/layouts/PostLayout.astro";
import Toc from '@/components/widgets/Toc.astro';
import { ArrowLeft, ArrowRight } from "@lucide/astro";

export async function getStaticPaths() {
	const postEntries = await getCollection("post");
	return postEntries.map((entry) => {
		const slugString = entry.id;
		return {
			params: { slug: slugString },
			props: { entry },
		};
	});
}

const { entry } = Astro.props;

if (!entry) {
	return Astro.redirect("/404");
}

const { Content, headings } = await render(entry);
const filtered = headings.filter(h => h.depth <= 2);

// Get all posts for prev/next navigation
const allPosts = await getCollection("post");
const sortedPosts = allPosts
	.filter(p => !p.data.draft)
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const currentIndex = sortedPosts.findIndex(p => p.id === entry.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

const formattedDate = new Date(entry.data.publishDate).toLocaleDateString('zh-CN', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
	timeZone: 'Asia/Shanghai',
});
---

<PostLayout title={`${entry.data.title} — YouthGT`} description={entry.data.description}>
	<!-- Reading progress bar -->
	<div id="reading-progress" class="reading-progress" style="transform: scaleX(0);"></div>

	<div class="post article">
		<main class="relative site-container mx-auto my-8 md:my-12">
			<!-- Article header -->
			<header class="article-header">
				<!-- Tags -->
				<div class="article-tags">
					{entry.data.tags && entry.data.tags.length > 0 ? (
						entry.data.tags.map(tag => (
							<a href={`/tags/${encodeURIComponent(tag)}`} class="article-tag letter-spacing-wide text-xs hover:opacity-80 transition-opacity">{tag}</a>
						))
					) : (
						<span class="article-tag text-xs">Article</span>
					)}
				</div>

				<!-- Title -->
				<h1 class="article-title font-brand">
					{entry.data.title}
				</h1>

				<!-- Metadata -->
				<div class="article-meta text-sm text-neutral-500 dark:text-neutral-400">
					<time datetime={entry.data.publishDate.toISOString()}>
						{formattedDate}
					</time>
					{entry.data.read && (
						<>
							<span class="article-meta-divider"></span>
							<span>{entry.data.read} min read</span>
						</>
					)}
				</div>
			</header>

			<!-- Content area -->
			<div class="relative flex flex-col lg:flex-row gap-8 lg:gap-12 xl:gap-16">
				<!-- Left TOC - Fixed on desktop -->
				<aside class="relative hidden lg:block lg:w-40 xl:w-50 flex-shrink-0">
					<div class="toc-sticky-wrapper">
						<Toc headings={filtered} />
					</div>
				</aside>

				<!-- Article content -->
				<div class="relative flex-1 min-w-0 w-full lg:max-w-none">
					<article class="article-wrapper">
						<div class="article-content">
							<Content />
						</div>
					</article>

					<!-- Prev/Next Navigation -->
					{(prevPost || nextPost) && (
						<div class="mt-16 pt-8 border-t border-dashed border-neutral-200 dark:border-neutral-700">
							<div class="flex justify-between gap-4">
								{prevPost ? (
									<a
										href={`/blog/${prevPost.id}`}
										class="group flex-1 flex flex-col gap-1 p-4 rounded-xl border border-primary/10 dark:border-neutral-700 hover:bg-bg-secondary dark:hover:bg-bg-secondary-dark transition-all duration-200"
									>
										<span class="flex items-center gap-1 text-xs text-neutral-400 dark:text-neutral-500">
											<ArrowLeft size={14} /> 上一篇
										</span>
										<span class="text-sm font-medium text-neutral-700 dark:text-neutral-300 group-hover:text-primary dark:group-hover:text-primary-light transition-colors line-clamp-2">
											{prevPost.data.title}
										</span>
									</a>
								) : <div class="flex-1"></div>}
								{nextPost ? (
									<a
										href={`/blog/${nextPost.id}`}
										class="group flex-1 flex flex-col gap-1 p-4 rounded-xl border border-primary/10 dark:border-neutral-700 hover:bg-bg-secondary dark:hover:bg-bg-secondary-dark transition-all duration-200 text-right"
									>
										<span class="flex items-center gap-1 text-xs text-neutral-400 dark:text-neutral-500 justify-end">
											下一篇 <ArrowRight size={14} />
										</span>
										<span class="text-sm font-medium text-neutral-700 dark:text-neutral-300 group-hover:text-primary dark:group-hover:text-primary-light transition-colors line-clamp-2">
											{nextPost.data.title}
										</span>
									</a>
								) : <div class="flex-1"></div>}
							</div>
						</div>
					)}
				</div>
			</div>
		</main>
	</div>
</PostLayout>

<style>
.toc-sticky-wrapper {
  position: sticky;
  top: 8rem;
}
</style>

<script>
// Reading progress bar
function updateReadingProgress() {
  const progressBar = document.getElementById('reading-progress');
  if (!progressBar) return;

  const windowHeight = window.innerHeight;
  const documentHeight = document.documentElement.scrollHeight;
  const scrollTop = window.scrollY;
  const scrollPercentage = (scrollTop / (documentHeight - windowHeight)) * 100;

  progressBar.style.transform = `scaleX(${Math.min(scrollPercentage / 100, 1)})`;
}

window.addEventListener('scroll', updateReadingProgress, { passive: true });
document.addEventListener('DOMContentLoaded', updateReadingProgress);
updateReadingProgress();
</script>
