---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/elements/PageHeader.astro";
import { siteConfig } from "@/config/site";

---

<Layout
  title="关于 — YouthGT"
  description="YouthGT 的个人简介"
>
  <section class="site-container my-12">
    <PageHeader
      title="关于我"
      description="分享自己学习过程中遇到的一些问题"
    />
  </section>

  <section class="site-container max-w-3xl mx-auto pb-24">
    <article class="space-y-10">

      <div data-aos="fade-up-xs" data-aos-once="true">
        <div class="space-y-4 text-neutral-600 dark:text-neutral-300 leading-relaxed">
          <p>
            你好！我是 <strong>YouthGT</strong>，一名热爱技术的学习者。
          </p>
          <p>
            这个博客记录了我在编程、嵌入式开发、Android 编译、PCB 设计等领域的学习心得与问题解决方案。希望能帮助到遇到同样问题的朋友们。
          </p>
          <p>
            从最初的 Hexo 博客，到现在的 Astro 站点，这个博客陪伴我走过了技术成长的各个阶段。
          </p>
        </div>
      </div>

      <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700"></div>

      <!-- Contact -->
      <div data-aos="fade-up-xs" data-aos-delay="100" data-aos-once="true">
        <h2 class="text-2xl font-brand text-neutral-800 dark:text-neutral-100 mb-4">联系我</h2>
        <div class="space-y-3 text-neutral-600 dark:text-neutral-300">
          <p class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
            <span>GitHub：</span>
            <a href={siteConfig.social.github} class="text-primary hover:underline" target="_blank">YouthGT</a>
          </p>

        </div>
      </div>

    </article>
  </section>
</Layout>
