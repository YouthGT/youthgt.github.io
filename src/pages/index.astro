---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import BlogCard from "@/components/cards/BlogCard.astro";
import { siteConfig } from "@/config/site";
import Button from "@/components/ui/Button.astro";
import { ArrowRight } from "@lucide/astro";

const allPosts = await getCollection("post");

// Sort by publishDate descending
let posts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

// Filter out drafts
posts = posts.filter((post) => !post.data.draft);

// Find featured posts
const featuredPosts = posts.filter((post) => post.data.featured);
const recentPosts = posts.filter((post) => !post.data.featured).slice(0, 6);
---

<Layout
  title={siteConfig.meta.title}
  description={siteConfig.meta.description}
>

  <!-- Hero Section -->
  <section class="site-container pt-20 pb-12 md:pt-28 md:pb-16" data-aos="fade-up-xs" data-aos-once="true">
    <div class="max-w-3xl">
      <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-xs font-medium text-primary dark:border-primary-light/20 dark:bg-primary-light/10 dark:text-primary-light">
        分享学习过程中的经验与总结
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-brand leading-[1.08] tracking-normal text-neutral-800 dark:text-neutral-100">
        {siteConfig.title}
      </h1>
      <p class="mt-5 max-w-xl text-base leading-8 text-neutral-600 dark:text-neutral-300">
        编程 · 嵌入式 · Android · PCB · 技术笔记
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Button url="/blog" type="fill">
          浏览文章 <ArrowRight size={16} />
        </Button>
        <Button url="/about">
          关于我
        </Button>
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 site-container"></div>

  <!-- Featured Posts -->
  {featuredPosts.length > 0 && (
    <section class="site-container py-12 md:py-16">
      <h2 class="text-2xl md:text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-8" data-aos="fade-up-sm" data-aos-once="true">
        精选文章
      </h2>
      <div class="grid gap-6 md:grid-cols-2">
        {featuredPosts.map((post, i) => {
          const link = `/blog/${post.id}`;
          return (
            <div data-aos="fade-up-sm" data-aos-delay={i * 100} data-aos-once="true">
              <BlogCard
                layout={featuredPosts.length === 1 ? "horizontal" : "vertical"}
                content={{ ...post.data, link, slug: post.id }}
              />
            </div>
          );
        })}
      </div>
    </section>
  )}

  <!-- Recent Posts -->
  <section class="site-container py-12 md:py-16" data-aos="fade-up-sm" data-aos-once="true">
    <h2 class="text-2xl md:text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-8">
      最新文章
    </h2>
    <div class="grid gap-x-6 gap-y-10 md:grid-cols-2 xl:grid-cols-3">
      {recentPosts.map((post, index) => {
        const link = `/blog/${post.id}`;
        return (
          <div
            data-aos="fade-up-sm"
            data-aos-delay={(index % 3) * 100}
            data-aos-once="true"
          >
            <BlogCard
              content={{ ...post.data, link, slug: post.id }}
            />
          </div>
        );
      })}
    </div>

    {posts.length > 6 && (
      <div class="flex justify-center mt-12">
        <Button url="/blog" type="fill" className="w-full max-w-60">
          查看全部文章 <ArrowRight size={16} />
        </Button>
      </div>
    )}
  </section>

</Layout>
